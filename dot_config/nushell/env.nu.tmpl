# Nushell env — rendered by chezmoi from .chezmoidata/sh.yaml.

# PATH
$env.PATH = ($env.PATH | prepend [
{{- range .paths }}
    "{{ . | replace "~" $.chezmoi.homeDir }}"
{{- end }}
{{- if eq .chezmoi.os "darwin" }}
    "/opt/homebrew/bin"
    "/opt/homebrew/sbin"
{{- end }}
] | uniq)

# Environment
{{- range $k, $v := .env }}
$env.{{ $k }} = "{{ $v | replace "~" $.chezmoi.homeDir }}"
{{- end }}
{{- range $k, $v := (index .env_by_os .chezmoi.os) }}
$env.{{ $k }} = "{{ $v | replace "~" $.chezmoi.homeDir }}"
{{- end }}
{{ if dig "mise" false . }}
# mise: generate activation script (loaded by config.nu)
^mise activate nu | save --force ($nu.default-config-dir | path join "mise.nu")
{{ end }}
# starship: generate prompt init (loaded by config.nu)
mkdir ~/.cache/starship
starship init nu | save --force ~/.cache/starship/init.nu
