#!/bin/bash
set -eu
{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/brew shellenv)"
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile"
{{ if dig "mise" false . }}
# mise is prompt-gated, so it's bundled here, not in the static Brewfile.
brew bundle --file=- <<<'brew "mise"'
{{ end -}}
{{ end -}}
